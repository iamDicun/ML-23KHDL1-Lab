# Server Configuration
PORT=5000
NODE_ENV=development
API_KEY=your_secret_api_key_here

JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Database Configuration (Supabase Postgres)
DATABASE_URL=postgresql://postgres:your_password@your-project-ref.supabase.co:5432/postgres
DB_HOST=your-project-ref.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=your_password

# AI model service (FastAPI app.py)
AI_MODEL_API_BASE_URL=https://huggingface.co/spaces/wokogaming/asba
AI_MODEL_API_TIMEOUT_MS=180000
